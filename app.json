{
  "expo": {
    "name": "Cookez",
    "slug": "cookez",
    "version": "2.0.0",
    "privacy": "hidden",
    "runtimeVersion": "2.0.0",
    "updates": {
      "url": "https://u.expo.dev/ffa99151-e290-4b35-a40f-aafbf548676b"
    },
    "orientation": "portrait",
    "icon": "./assets/logo/cook.png",
    "scheme": "cookez",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.v2.cookez",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/cookez_logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.v2.cookez"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/cook-black&white.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ffa99151-e290-4b35-a40f-aafbf548676b"
      }
    },
    "owner": "wycherley"
  }
}
